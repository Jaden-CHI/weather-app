# ── Database ──────────────────────────────────
POSTGRES_DB=weatherapp
POSTGRES_USER=weather
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://weather:changeme@db:5432/weatherapp

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── 기상청 공공데이터 (data.go.kr 발급) ──────────
KMA_API_KEY=YOUR_KMA_SERVICE_KEY_HERE

# ── 국립해양조사원 KHOA ────────────────────────
KHOA_API_KEY=YOUR_KHOA_SERVICE_KEY_HERE

# ── Anthropic Claude API ──────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ── 앱 설정 ───────────────────────────────────
USE_MOCK_DATA=true          # true: 더미 데이터 사용 / false: 실제 API 호출
WEATHER_CACHE_TTL=10800     # Redis TTL 초 단위 (기본 3시간)
WORKER_INTERVAL_MINUTES=60  # 배치 수집 주기 (분)
